# .env.local.example
# Copy to .env.local — Next.js loads it automatically in dev mode.
# Tauri production builds embed these at build time.

# Backend API base URL (default: local FastAPI server)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8765

# Override to a custom port if 8765 is taken
# NEXT_PUBLIC_API_URL=http://127.0.0.1:9000
