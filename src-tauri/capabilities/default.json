{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "PrankCam main window permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",

    "shell:allow-spawn",
    "shell:allow-kill",
    "shell:allow-stdin-write",

    "dialog:allow-open",
    "dialog:allow-save",

    "process:allow-exit",
    "process:allow-restart",

    "http:default",
    "http:allow-fetch",

    "log:allow-log",
    "log:allow-print-filter"
  ]
}
