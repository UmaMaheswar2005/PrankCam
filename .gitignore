# PrankCam .gitignore

# Python / Backend
backend/.venv/
backend/__pycache__/
backend/*.pyc
backend/*.spec
backend/build/            # PyInstaller build artifacts
backend/dist/             # PyInstaller output
backend/weights/          # model weights can be hundreds of MB — never commit
*.egg-info/
.pytest_cache/

# Node / Next.js
node_modules/
.next/
out/
.env.local

# Rust / Tauri
src-tauri/target/
src-tauri/gen/            # Auto-generated schemas by Tauri v2
src-tauri/binaries/prankcam-backend* # Do NOT commit compiled 30MB+ sidecar binaries!

# Installer drivers (If you download them locally, they are huge)
backend/drivers/

# OS
.DS_Store
Thumbs.db
*.swp

# IDE
.vscode/
.idea/

# PyInstaller temp
_internal/